        <script>
            function init() {
                new Vue({
                    el: '#app',
                    data: function () {
                        return {
                            isBgmPlay: false,
                        }
                    },
                    methods: {
                        bgmStatus() {
                            const audio = this.$refs.bgm
                            if (audio.paused) {
                                this.isBgmPlay = true
                                this.bgmVolume()
                                console.log('播放')
                            } else {
                                this.isBgmPlay = false
                                audio.pause()
                                console.log('暂停')
                            }
                        },
                        bgmVolume() {
                            const audio = this.$refs.bgm
                            audio.volume = 0; // 初始音量为0
                            audio.play()
                            const targetVolume = 1; // 目标音量
                            const fadeDuration = 5000; // 渐变持续时间（毫秒）
                            const fadeInterval = 5; // 每次音量增加的时间间隔（毫秒）
                            const volumeStep = targetVolume / (fadeDuration / fadeInterval); // 每次增加的音量

                            const fadeAudioIn = setInterval(() => {
                                if (audio.volume < targetVolume) {
                                    audio.volume = Math.min(audio.volume + volumeStep, targetVolume);
                                } else {
                                    clearInterval(fadeAudioIn);
                                }
                            }, fadeInterval);
                        },
                        playBgm() {
                            const audio = this.$refs.bgm
                            if (audio.paused) {
                                this.bgmVolume()
                                this.isBgmPlay = true
                            }
                        },
                        smartOpen(id, val) {
                            popWin(id, val);
                        }
                    },
                })
            }
        </script>

